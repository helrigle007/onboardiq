# ═══════════════════════════════════════════════════
# OnboardIQ Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ── Required ──────────────────────────────────────
# Anthropic API key for Claude (generation + evaluation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voyage AI API key for embeddings
VOYAGE_API_KEY=voy-your-key-here

# ── Optional: Observability ───────────────────────
# LangSmith tracing (https://smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=onboardiq

# ── Tuning (defaults work well) ──────────────────
# Minimum eval score before regeneration (0.0-1.0)
EVAL_THRESHOLD=0.7
# Max regeneration attempts per guide
MAX_REGENERATIONS=2
# Number of sections per guide
GUIDE_SECTIONS_COUNT=6
# Chunking parameters (characters)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Chunks returned after reranking
RETRIEVAL_TOP_K=20
